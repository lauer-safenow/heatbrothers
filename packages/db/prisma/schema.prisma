datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  runtime  = "nodejs"
}

model Event {
  id          Int     @id @default(autoincrement())
  posthogId   String  @unique @map("posthog_id")
  eventType   String  @map("event_type")
  latitude    Float
  longitude   Float
  geohash     String?
  timestamp   Int
  posthogTs   String  @map("posthog_ts")
  distinctId  String  @map("distinct_id")
  env         String  @default("prod")
  eventSource String? @map("event_source")
  pssId       String? @map("pss_id")
  pssName     String? @map("pss_name")
  pssType     String? @map("pss_type")
  companyName String? @map("company_name")
  alarmSource String? @map("alarm_source")
  createdAt   Int     @default(dbgenerated("(unixepoch())")) @map("created_at")

  @@index([eventType], name: "idx_event_type")
  @@index([timestamp], name: "idx_timestamp")
  @@index([latitude, longitude], name: "idx_geo")
  @@index([geohash], name: "idx_geohash")
  @@index([distinctId], name: "idx_distinct_id")
  @@index([pssId], name: "idx_pss_id")
  @@index([eventSource], name: "idx_event_source")
  @@map("events")
}

model FeatureRequest {
  id          Int    @id @default(autoincrement())
  requestor   String
  description String
  upvotes     Int    @default(0)
  createdAt   Int    @default(dbgenerated("(unixepoch())")) @map("created_at")

  @@map("feature_requests")
}
