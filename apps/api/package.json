{
  "name": "@heatbrothers/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '../web/node_modules/**' src/index.ts",
    "serve": "NODE_ENV=production tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "sync": "tsx src/sync/run-sync.ts"
  },
  "dependencies": {
    "@heatbrothers/db": "workspace:*",
    "@heatbrothers/shared": "workspace:*",
    "@webkitty/geo-rev": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "vite": "^6.1.0"
  }
}
